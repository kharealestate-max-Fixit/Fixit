# FixIt backend — copy to .env and fill in (or export these in your shell).
# Every var is OPTIONAL: with none set, the app runs with mock AI + simulated payments.

# Server
PORT=3001
# Public origin used to build Stripe Connect onboarding return links.
PUBLIC_URL=http://localhost:3001

# Database — leave unset for embedded dev Postgres (npm run dev).
# In production, point at a managed Postgres (Railway/Render/Neon/Supabase):
# DATABASE_URL=postgres://user:pass@host:5432/fixit

# Claude AI photo analysis (else mock diagnosis is returned)
# ANTHROPIC_API_KEY=sk-ant-...

# Stripe — real payments (else simulated). Get keys: https://dashboard.stripe.com/test/apikeys
# BOTH are needed to enable the real card checkout:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret — see README "Stripe setup". With the Stripe CLI:
#   stripe listen --forward-to localhost:3001/api/webhooks/stripe
# STRIPE_WEBHOOK_SECRET=whsec_...
# Platform fee per booking in cents (default 999 = $9.99)
# PLATFORM_FEE_CENTS=999
